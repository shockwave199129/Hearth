{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hearth Installer",
  "version": "0.2.6",
  "identifier": "com.hearth.installer",
  "build": {
    "frontendDist": "../installer-ui/dist",
    "devUrl": "http://127.0.0.1:5174",
    "beforeDevCommand": "pnpm -C ../installer-ui run dev",
    "beforeBuildCommand": "pnpm -C ../installer-ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "Hearth Installation Wizard",
        "width": 720,
        "height": 620,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "macOS": [
      {
        "title": "Hearth Installation Wizard",
        "width": 700,
        "height": 600,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "linux": [
      {
        "title": "Hearth Installation Wizard",
        "width": 700,
        "height": 600,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "msi", "nsis", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
