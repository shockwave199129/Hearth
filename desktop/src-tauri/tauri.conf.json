{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hearth",
  "version": "0.2.4",
  "identifier": "com.hearth.desktop",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://127.0.0.1:48176",
    "beforeDevCommand": "pnpm -C ../frontend run dev",
    "beforeBuildCommand": "pnpm -C ../frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "Hearth",
        "width": 900,
        "height": 700,
        "minWidth": 480,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "msi", "nsis", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/hearth-backend": "backend",
      "resources/llama-cpp": "llama-cpp",
      "resources/setup-python": "setup-python"
    }
  }
}
