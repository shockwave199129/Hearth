# Copy this file to backend/.env and fill in what you need — see
# app/config.py's load_dotenv() call. Only used for local dev; the packaged
# desktop app sets these itself (see scripts/build_backend.sh/.ps1) and
# ignores this file entirely.

# Path to the llama.cpp llama-server binary. Defaults to plain
# "llama-server" (expects it on PATH) if unset. Build/download one
# yourself (https://github.com/ggerganov/llama.cpp) or run
# `python scripts/fetch_llama_cpp.py` from the repo root, which places a
# prebuilt binary at desktop/src-tauri/resources/llama-cpp/llama-server(.exe).
# LLAMA_SERVER_BIN=/path/to/llama-server
